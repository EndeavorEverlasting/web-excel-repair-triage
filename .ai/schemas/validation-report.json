{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ValidationReport",
  "type": "object",
  "properties": {
    "timestamp": { "type": "string", "format": "date-time" },
    "run_id": { "type": "string" },
    "passed": { "type": "boolean" },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "part": { "type": "string" }
        },
        "required": ["code", "message"]
      }
    }
  },
  "required": ["timestamp", "run_id", "passed", "issues"]
}
