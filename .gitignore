# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Generated outputs from the triage tool ────────────────────────────────────
# Outputs/ is runtime-generated. Keep only curated reference JSONs tracked.
Outputs/**
!Outputs/
!Outputs/cf_dict_deprecated.json
!Outputs/dv_spec_deprecated.json

# Legacy location (root-level patch file)
*_patched.xlsx
# Root-level recipe if accidentally saved there
patch_recipe.json

# Common local workbook artifacts (keep out of git)
CANDIDATE_*.xlsx
web_repaired_*.xlsx
README_CANDIDATE_*.xlsx

# ── Streamlit runtime ─────────────────────────────────────────────────────────
.streamlit/

# ── Deprecated archive (binary .xlsx history, not needed in repo) ───────────
Deprecated/

# ── OneDrive export archives (large, not needed on other machines) ────────────
OneDrive_*.zip

# ── OS noise ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

