# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Input folders ────────────────────────────────────────────────────────────
# Candidates/ and Repaired/ are user drop-zones. Keep the folders tracked via
# .gitkeep so users see them, but ignore all actual workbook contents.
Candidates/**
!Candidates/
!Candidates/.gitkeep
Repaired/**
!Repaired/
!Repaired/.gitkeep

# ── Dated artifact intake ─────────────────────────────────────────────────────
# ArtifactIntake/ tracks the folder map and README guidance only. Real admin,
# billing, roster, dashboard, and tooling workbooks stay local unless sanitized.
ArtifactIntake/**/*.xlsx
ArtifactIntake/**/*.xlsm
ArtifactIntake/**/*.xls
ArtifactIntake/**/*.xlsb
ArtifactIntake/**/*.csv
ArtifactIntake/**/*.tsv
ArtifactIntake/**/*.zip
ArtifactIntake/**/*.pdf
ArtifactIntake/**/*.docx
ArtifactIntake/**/*.png
ArtifactIntake/**/*.jpg
ArtifactIntake/**/*.jpeg
ArtifactIntake/**/*.webp
!ArtifactIntake/**/README.md
!ArtifactIntake/**/.gitkeep

# ── Generated outputs from the triage tool ────────────────────────────────────
# Outputs/ is runtime-generated. Keep only curated reference JSONs tracked.
Outputs/**
!Outputs/
!Outputs/cf_dict_deprecated.json
!Outputs/dv_spec_deprecated.json

# Legacy location (root-level patch file)
/*_patched.xlsx
# Root-level recipe if accidentally saved there
/patch_recipe.json

# Common local workbook artifacts (keep out of git)
# (root-only; do NOT ignore sample corpora under Deprecated/)
/CANDIDATE_*.xlsx
/web_repaired_*.xlsx
/README_CANDIDATE_*.xlsx

# ── Streamlit runtime ─────────────────────────────────────────────────────────
.streamlit/

# ── Deprecated archive policy ────────────────────────────────────────────────
# Keep curated, high-signal samples under Deprecated/ tracked,
# but ignore bulky/reproducible runtime outputs.
Deprecated/outputs_pre_i100/

# ── OneDrive export archives (large, not needed on other machines) ────────────
OneDrive_*.zip

# ── OS noise ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo


# ── Billing pipeline runtime outputs ────────────────────────────────────────
billing_runs/

# Generated billing report outputs
billing_runs_tmp/

# Local script env overrides (secrets; never commit)
scripts/online_env.local.ps1
scripts/*.local.ps1
scripts/artifacts/*.local

# Local payload drop zone and decode output — never commit raw internal workbooks
Workbook Payload Artifacts/
RecoveredArtifacts/
